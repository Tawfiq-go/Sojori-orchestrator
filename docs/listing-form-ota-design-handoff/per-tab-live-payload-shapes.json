{
  "_comment": "Forme logique du JSON « live » par onglet (après buildListingTabLivePayload) — pour wireframes sans coller le brut.",
  "basic": "objet plat : name, propertyType*, owner*, description[], flags active/staging/draft, capacité/surface",
  "address": "objet plat : address, city, geo lat/lng, howToArrive, timeZoneName, cityId",
  "media": "{ listingImages[], videoTourUrl, imagesCount }",
  "equipment": "{ listingAmenitiesIds: array of refs + amenityData }",
  "pricing": "mix tarifs + roomTypes[] + fees + taxes",
  "availability": "min/max nights, horaires check-in/out, schedule*, instantBookable, advanceNotice*",
  "deposit": "{ deposit, securityDeposit, additionalFees }",
  "channels": "channelManager, channex*, otaChannelsSnapshot{channels[]}, distribution",
  "roomtypes": "{ roomTypes[], compositionRooms }",
  "licenses": "{ licenceInfo: nested object }",
  "houserules": "description + horaires + houseRules + rulesAndInfo",
  "orchestration": "booleens orchestration_*",
  "cleaning": "paidCleaningConfig, freeCleaningConfig, frequency",
  "access": "{ accessDetails: array }",
  "whatsapp": "{ whatsappServiceSettings: array }",
  "concierge": "sous-ensemble flags orchestration transport/grocery/custom",
  "support": "arrivalPhone, arrivalEmail, orchestration_support",
  "rules": "description, rulesAndInfo, houseRules",
  "services": "{ services[], servicesCount }",
  "automsg": "messageCheckin[], messageCheckout[], messageGeneral, …",
  "wifi": "wifiUsername, wifiPassword",
  "autotasks": "{ tasks: array }",
  "iot": "iot, connectedDevices",
  "extras": "additionalFees, extra, distribution"
}
