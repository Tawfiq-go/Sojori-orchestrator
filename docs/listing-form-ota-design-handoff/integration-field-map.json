      "persistenceNote": "Liste amenities = srv-listing ; mock masqué quand id Mongo + API."
    },
    {
      "key": "pricing",
      "group": "LISTING",
      "liveDataSource": "api-document-keys-by-tab.pricing",
      "mockFormPaths": ["pricing.basePrice", "pricing.cleaningFee", "pricing.weekendMultiplier", "pricing.currency", "pricing.cityTax", "pricing.petFee", "pricing.minStay (utilisé aussi logique dispo)"],
      "persistenceNote": "Tarifs / roomTypes imbriqués côté API."
    },
    {
      "key": "availability",
      "group": "LISTING",
      "liveDataSource": "api-document-keys-by-tab.availability",
      "mockFormPaths": ["pricing.minStay", "availability.maxNights", "availability.preparationHoursBeforeArrival", "channels.allowInstantBook", "availability.notes"],
      "persistenceNote": "Attention : minStay est sur form.pricing dans le mock."
    },
    {
      "key": "deposit",
      "group": "LISTING",
      "liveDataSource": "deposit, securityDeposit, additionalFees",
      "mockFormPaths": ["deposit.*", "extras.* (onglet deposit fusionne extras REQUIRED_FIELDS)"],
      "persistenceNote": "Onglet deposit inclut extras dans completion — designer peut séparer visuellement deux cartes."
    },
    {
      "key": "channels",
      "group": "LISTING",
      "liveDataSource": "channelManager, channex*, otaChannelsSnapshot, distribution",
      "mockFormPaths": ["channels.preferredChannel", "channels.syncMode", "channels.allowInstantBook", "channels.channelNotes"],
      "persistenceNote": "Channex mapping peut être absent (direct) — message info, pas erreur fatale."
    },
    {
      "key": "roomtypes",
      "group": "LISTING",
      "liveDataSource": "roomTypes[], compositionRooms",
      "mockFormPaths": ["roomtypes.*"],
      "persistenceNote": "srv-listing roomTypes"
    },
    {
      "key": "licenses",
      "group": "LISTING",
