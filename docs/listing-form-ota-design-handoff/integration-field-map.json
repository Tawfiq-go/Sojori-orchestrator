{
  "_comment": "Pont design : chaque onglet = label UI, groupe, champs mock (paths), champs API (document by-id), persistance réelle.",
  "configTabsPut": ["whatsapp", "concierge", "support", "rules", "access"],
  "tabs": [
    {
      "key": "basic",
      "group": "LISTING",
      "liveDataSource": "GET /listings/by-id → voir api-document-keys-by-tab.basic",
      "mockFormPaths": ["basic.name", "basic.type", "basic.ownerName", "basic.status", "basic.bedrooms", "basic.bathrooms", "basic.guests", "basic.surface", "basic.beds", "basic.shortDescription", "basic.longDescription"],
      "persistenceNote": "Mise à jour réelle via dashboard admin / update-property (srv-listing), pas le bouton brouillon orchestrateur seul."
    },
    {
      "key": "address",
      "group": "LISTING",
      "liveDataSource": "api-document-keys-by-tab.address",
      "mockFormPaths": ["address.street", "address.postalCode", "address.city", "address.region", "address.country", "address.countryCode", "address.latitude", "address.longitude", "address.accessLandmark"],
      "persistenceNote": "srv-listing"
    },
    {
      "key": "media",
      "group": "LISTING",
      "liveDataSource": "listingImages[], videoTourUrl",
      "mockFormPaths": ["media.coverPhoto", "media.galleryCount", "media.photoNotes", "media.videoTourUrl"],
      "persistenceNote": "Galerie = API ; mock complète l’UX jusqu’à brancher upload."
    },
    {
      "key": "equipment",
      "group": "LISTING",
      "liveDataSource": "listingAmenitiesIds[] (détails via endpoint amenities catalogue)",
