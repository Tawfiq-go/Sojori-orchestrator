# Configuration locale pour le développement
# Copie ce fichier en .env.local et modifie selon tes besoins

# Mode développement sans authentification (⚠️ JAMAIS en production!)
# Décommenter pour désactiver l'auth frontend
# VITE_DISABLE_AUTH=true

# URL des APIs (recommandé — même pattern que le reste du dashboard)
VITE_API_URL=https://dev.sojori.com

# Proxy Vite (:4174) — par défaut fulltask + fullchatbot passent aussi par dev.sojori.com
# (srv-admin → K8s). Pas besoin de port-forward sauf debug service isolé :
# VITE_FULLTASK_URL=http://127.0.0.1:4015
# VITE_FULLCHATBOT_URL=http://127.0.0.1:4016
# VITE_DEV_PROXY_TARGET=https://dev.sojori.com

# Dev token pour contourner CORS depuis localhost (obligatoire avec VITE_API_URL)
VITE_DEV_TOKEN=your_dev_token_here
