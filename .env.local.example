# Configuration locale pour le développement
# Copie ce fichier en .env.local et modifie selon tes besoins

# Mode développement sans authentification (⚠️ JAMAIS en production!)
# VITE_DISABLE_AUTH=true

# Backend prod — front local via proxy Vite (/api → sojori.com). Ne plus utiliser dev.sojori.com.
# Futur front déployé pro : app.sojori.com (build statique, même API sojori.com).
# VITE_API_URL=https://sojori.com

# Dev token pour contourner CORS depuis localhost (obligatoire si VITE_API_URL absolu)
VITE_DEV_TOKEN=your_dev_token_here

# Listing OTA (amenities/images) — même défaut que le proxy ; override si srv-listing local :
# VITE_LISTING_URL=http://127.0.0.1:4001

# Microservices locaux (4000–4015) — opt-in uniquement
# VITE_USE_LOCAL_MICROSERVICES=true
# VITE_API_URL=http://localhost
