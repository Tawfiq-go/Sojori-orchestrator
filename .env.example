# Configuration de l'environnement pour Sojori Orchestrator

# URL de l'API backend
# Dev local : laisser vide → proxy Vite /api → https://sojori.com (prod)
# Override explicite : VITE_API_URL=https://sojori.com
# Futur front pro déployé : app.sojori.com (API inchangée : sojori.com)
VITE_API_URL=

# Anciennes variables CRA (REACT_APP_*) : sous Vite, exposer avec le préfixe VITE_
# VITE_REACT_APP_REMOTE_APP_URL=https://sojori.com
# VITE_REACT_APP_ORCHESTRATOR_URL=https://sojori.com

# Calendar Service URL (srv-calendar - port 4006) — si port-forward local
# VITE_API_BASE_URL=http://localhost:4006

# Exemples :
# VITE_API_URL=                           # Proxy Vite → sojori.com (recommandé)
# VITE_API_URL=https://sojori.com       # Appels absolus (CORS + VITE_DEV_TOKEN)
# VITE_LISTING_URL=https://sojori.com   # Catalogue OTA listing (amenities/images)
