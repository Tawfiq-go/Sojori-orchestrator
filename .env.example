# Configuration de l'environnement pour Sojori Orchestrator

# URL de l'API backend
# En développement local avec microservices sur ports locaux, laisser vide ou mettre http://localhost
# En développement avec API distante : https://dev.sojori.com
# En production : https://dev.sojori.com (ou votre URL de production)
VITE_API_URL=http://localhost

# Exemples de configuration :
# VITE_API_URL=                           # Utilisera http://localhost avec ports locaux (4000, 4002, etc.)
# VITE_API_URL=http://localhost           # Même chose
# VITE_API_URL=https://dev.sojori.com     # API distante (dev/staging)
# VITE_API_URL=https://api.sojori.com     # Production (si différent)
